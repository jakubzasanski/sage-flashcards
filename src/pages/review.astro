---
import Layout from "@/layouts/Layout.astro";
import ReviewSession from "@/components/review/ReviewSession";

// Protected by middleware (PROTECTED_ROUTES); unauthenticated users are redirected to /auth/signin.
const { user } = Astro.locals;
---

<Layout title="Review">
  <main class="bg-cosmic min-h-screen px-4 py-10 text-white">
    <div class="mx-auto w-full max-w-2xl">
      <header class="mb-8 text-center">
        <h1 class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          Review
        </h1>
        <p class="text-sm text-blue-100/60">
          Reveal each answer with <kbd class="rounded bg-white/15 px-1.5 text-xs">Space</kbd>, then rate your recall
          <kbd class="rounded bg-white/15 px-1.5 text-xs">1</kbd>–<kbd class="rounded bg-white/15 px-1.5 text-xs">4</kbd
          >.
        </p>
        <p class="mt-1 text-xs text-blue-100/40">Signed in as {user?.email}</p>
      </header>

      <ReviewSession client:load />
    </div>
  </main>
</Layout>
