---
import AppLayout from "@/layouts/AppLayout.astro";
import DeckView from "@/components/deck/DeckView";
import { t } from "@/i18n";

// Protected by middleware (PROTECTED_ROUTES); unauthenticated users are redirected to /auth/signin.
const { locale } = Astro.locals;
---

<AppLayout title="Your deck">
  <div class="page-head">
    <h1>{t(locale, "deck.title")}</h1>
    <p>{t(locale, "deck.sub")}</p>
  </div>
  <DeckView locale={locale} client:load />
</AppLayout>
