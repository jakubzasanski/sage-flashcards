---
import AppLayout from "@/layouts/AppLayout.astro";
import ManualCardForm from "@/components/manual/ManualCardForm";
import { t } from "@/i18n";

// Protected by middleware (PROTECTED_ROUTES includes "/cards"); unauthenticated users are
// redirected to /auth/signin.
const { locale } = Astro.locals;
---

<AppLayout title="New card">
  <div class="page-head">
    <h1>{t(locale, "new.title")}</h1>
    <p>{t(locale, "new.sub")}</p>
  </div>
  <ManualCardForm locale={locale} client:load />
</AppLayout>
