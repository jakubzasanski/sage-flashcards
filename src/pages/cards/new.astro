---
import Layout from "@/layouts/Layout.astro";
import ManualCardForm from "@/components/manual/ManualCardForm";

// Protected by middleware (PROTECTED_ROUTES includes "/cards"); unauthenticated users are
// redirected to /auth/signin.
const { user } = Astro.locals;
---

<Layout title="New card">
  <main class="bg-cosmic min-h-screen px-4 py-10 text-white">
    <div class="mx-auto w-full max-w-2xl">
      <header class="mb-8 text-center">
        <h1 class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          New card
        </h1>
        <p class="text-sm text-blue-100/60">Type a question and an answer to add a card to your deck.</p>
        <p class="mt-1 text-xs text-blue-100/40">Signed in as {user?.email}</p>
      </header>

      <ManualCardForm client:load />
    </div>
  </main>
</Layout>
