---
import Layout from "@/layouts/Layout.astro";
import SignInForm from "@/components/auth/SignInForm";
import SageLeaf from "@/components/brand/SageLeaf.astro";
import { t } from "@/i18n";

const { locale } = Astro.locals;
const error = Astro.url.searchParams.get("error");
const reset = Astro.url.searchParams.get("reset");
---

<Layout title="Sign in — Sage Flashcards">
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="brand">
        <SageLeaf class="logo" size={30} />
        <span class="wordmark">Sage Flashcards</span>
      </div>
      <h1>{t(locale, "auth.welcomeTitle")}</h1>
      <p class="sub">{t(locale, "auth.welcomeSub")}</p>
      {reset && <p class="reset-note">{t(locale, "auth.resetSent")}</p>}
      <SignInForm serverError={error} locale={locale} client:load />
      <div class="auth-row">
        <a href="/auth/forgot-password">{t(locale, "auth.forgot")}</a>
      </div>
      <p class="auth-foot">
        {t(locale, "auth.noAccount")}
        <a href="/auth/signup">{t(locale, "auth.signup")}</a>
      </p>
    </div>
  </div>
</Layout>

<style>
  .reset-note {
    margin: -10px 0 18px;
    text-align: center;
    font-size: 0.85rem;
    color: var(--accent-deep);
  }
</style>
