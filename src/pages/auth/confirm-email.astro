---
import Layout from "@/layouts/Layout.astro";
import { t } from "@/i18n";

const { locale } = Astro.locals;
const isAutoConfirmed = import.meta.env.DEV;

const content = isAutoConfirmed
  ? {
      emoji: "✅",
      heading: t(locale, "auth.confirmedTitle"),
      description: t(locale, "auth.confirmedSub"),
      linkText: t(locale, "auth.goSignin"),
    }
  : {
      emoji: "📧",
      heading: t(locale, "auth.checkEmail"),
      description: t(locale, "auth.confirmSub"),
      linkText: t(locale, "auth.backToSignin"),
    };
---

<Layout title={`${content.heading} — Sage Flashcards`}>
  <div class="auth-wrap">
    <div class="auth-card auth-center">
      <div class="auth-emoji">{content.emoji}</div>
      <h1>{content.heading}</h1>
      <p class="sub">{content.description}</p>
      <a class="linkback" href="/auth/signin">{content.linkText}</a>
    </div>
  </div>
</Layout>
