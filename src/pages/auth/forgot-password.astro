---
import Layout from "@/layouts/Layout.astro";
import ForgotPasswordForm from "@/components/auth/ForgotPasswordForm";
import SageLeaf from "@/components/brand/SageLeaf.astro";
import BackHome from "@/components/auth/BackHome.astro";
import { t } from "@/i18n";

const { locale } = Astro.locals;
const error = Astro.url.searchParams.get("error");
const sent = Astro.url.searchParams.get("sent");
---

<Layout title="Forgot password — Sage Flashcards">
  <div class="auth-wrap">
    <BackHome />
    {
      sent ? (
        <div class="auth-card auth-center">
          <div class="auth-emoji">📧</div>
          <h1>{t(locale, "auth.checkEmail")}</h1>
          <p class="sub">{t(locale, "auth.resetSent")}</p>
          <a class="linkback" href="/auth/signin">
            {t(locale, "auth.backToSignin")}
          </a>
        </div>
      ) : (
        <div class="auth-card">
          <a class="brand" href="/" aria-label="Sage Flashcards — home">
            <SageLeaf class="logo" size={30} />
            <span class="wordmark">
              <span class="wm-sage">Sage</span> Flashcards
            </span>
          </a>
          <h1>{t(locale, "auth.forgotTitle")}</h1>
          <p class="sub">{t(locale, "auth.forgotSub")}</p>
          <ForgotPasswordForm serverError={error} locale={locale} client:load />
          <p class="auth-foot">
            {t(locale, "auth.rememberPw")} <a href="/auth/signin">{t(locale, "auth.signin")}</a>
          </p>
        </div>
      )
    }
  </div>
</Layout>
