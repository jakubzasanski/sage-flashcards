---
import Layout from "@/layouts/Layout.astro";
import SignUpForm from "@/components/auth/SignUpForm";
import SageLeaf from "@/components/brand/SageLeaf.astro";
import BackHome from "@/components/auth/BackHome.astro";
import { t } from "@/i18n";

const { locale } = Astro.locals;
const error = Astro.url.searchParams.get("error");
---

<Layout title="Sign up — Sage Flashcards">
  <div class="auth-wrap">
    <BackHome />
    <div class="auth-card">
      <a class="brand" href="/" aria-label="Sage Flashcards — home">
        <SageLeaf class="logo" size={30} />
        <span class="wordmark"><span class="wm-sage">Sage</span> Flashcards</span>
      </a>
      <h1>{t(locale, "auth.signupTitle")}</h1>
      <p class="sub">{t(locale, "auth.signupSub")}</p>
      <SignUpForm serverError={error} locale={locale} client:load />
      <p class="auth-foot">
        {t(locale, "auth.haveAccount")}
        <a href="/auth/signin">{t(locale, "auth.signin")}</a>
      </p>
    </div>
  </div>
</Layout>
