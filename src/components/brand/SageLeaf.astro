---
// The Sage mark — two curved leaves with a delicate midrib. Self-contained so the
// gradients live with each instance; ids are unique per render to allow multiple on
// a page. Transparent (no drop shadow) so it sits cleanly on light and dark headers.
interface Props {
  size?: number;
  class?: string;
}
const { size = 30, class: className } = Astro.props;
const uid = Math.random().toString(36).slice(2, 9);
const lg = `sageLg-${uid}`;
const deep = `sageDeep-${uid}`;
---

<svg width={size} height={size} viewBox="0 0 96 96" aria-hidden="true" class:list={className}>
  <defs>
    <linearGradient id={lg} x1="0.1" y1="0" x2="0.9" y2="1">
      <stop offset="0" stop-color="#a6d68d"></stop>
      <stop offset="0.52" stop-color="#5f9a53"></stop>
      <stop offset="1" stop-color="#3a6739"></stop>
    </linearGradient>
    <linearGradient id={deep} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#4e7c4d"></stop>
      <stop offset="1" stop-color="#2c5130"></stop>
    </linearGradient>
  </defs>
  <g transform="translate(8,6) rotate(18 48 48) scale(0.78)">
    <path d="M34 84C18 60 24 26 70 14 70 44 60 74 34 84Z" fill={`url(#${deep})`}></path>
  </g>
  <g transform="translate(-4,2) rotate(-8 48 48) scale(0.92)">
    <path d="M34 84C18 60 24 26 70 14 70 44 60 74 34 84Z" fill={`url(#${lg})`}></path>
    <path
      d="M34 84C44 60 56 36 68 18"
      stroke="#fff"
      stroke-opacity="0.6"
      stroke-width="1.4"
      stroke-linecap="round"
      fill="none"></path>
  </g>
</svg>
