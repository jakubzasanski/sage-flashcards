---
import SageLeaf from "@/components/brand/SageLeaf.astro";
import { ThemeToggle } from "@/components/ThemeToggle";
import { LanguageToggle } from "@/components/LanguageToggle";
import { t } from "@/i18n";

const { locale } = Astro.locals;
---

<div id="landingView">
  <nav class="landing-nav" aria-label="Top">
    <div class="brand">
      <SageLeaf class="logo" size={30} />
      <span class="wordmark">Sage Flashcards</span>
    </div>
    <div class="top-right">
      <LanguageToggle locale={locale} client:load />
      <ThemeToggle client:load />
      <a class="btn btn-ghost" href="/auth/signin">{t(locale, "auth.signin")}</a>
    </div>
  </nav>

  <section class="hero">
    <SageLeaf class="leaf-xl" size={68} />
    <h1>{t(locale, "landing.h1pre")}<span class="accent">{t(locale, "landing.h1accent")}</span></h1>
    <p class="lede">{t(locale, "landing.lede")}</p>
    <div class="cta">
      <a class="btn btn-primary" href="/auth/signup">{t(locale, "landing.cta")}</a>
      <a class="btn btn-ghost" href="/auth/signin">{t(locale, "auth.signin")}</a>
    </div>
    <p class="reassure">{t(locale, "landing.reassure")}</p>
  </section>

  <section class="how">
    <div class="how-grid">
      <div class="step">
        <div class="ico">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"></path>
            <path d="M14 2v6h6"></path>
            <path d="M8 13h8M8 17h6"></path>
          </svg>
        </div>
        <span class="n">{t(locale, "landing.step1.n")}</span>
        <h3>{t(locale, "landing.step1.h")}</h3>
        <p>{t(locale, "landing.step1.p")}</p>
      </div>
      <div class="step">
        <div class="ico">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 3l1.6 5.4L19 10l-5.4 1.6L12 17l-1.6-5.4L5 10l5.4-1.6Z"></path>
          </svg>
        </div>
        <span class="n">{t(locale, "landing.step2.n")}</span>
        <h3>{t(locale, "landing.step2.h")}</h3>
        <p>{t(locale, "landing.step2.p")}</p>
      </div>
      <div class="step">
        <div class="ico">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M12 7v5l3 2"></path>
          </svg>
        </div>
        <span class="n">{t(locale, "landing.step3.n")}</span>
        <h3>{t(locale, "landing.step3.h")}</h3>
        <p>{t(locale, "landing.step3.p")}</p>
      </div>
    </div>
  </section>

  <section class="closing">
    <div class="closing-card">
      <h2>{t(locale, "landing.closing.h")}</h2>
      <p>{t(locale, "landing.closing.p")}</p>
      <a class="btn btn-primary" href="/auth/signup">{t(locale, "landing.cta2")}</a>
    </div>
  </section>
</div>
