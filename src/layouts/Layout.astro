---
import "../styles/global.css";
import Banner from "@/components/Banner.astro";
import { missingConfigs } from "@/lib/config-status";
import { t } from "@/i18n";
import { version } from "../../package.json";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sage Flashcards",
  description = "Paste your notes, let AI draft flashcards, and review them on a spaced-repetition schedule.",
} = Astro.props;
const ogImage = Astro.site ? new URL("/og-image.png", Astro.site).toString() : "/og-image.png";
const locale = Astro.locals.locale;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#6ba06a" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    {/* Apply the theme before first paint to avoid a flash of the wrong theme. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("sage-theme");
          var dark = stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches;
          if (dark) document.documentElement.classList.add("dark");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    {
      missingConfigs.map((cfg) => (
        <Banner variant="error">
          <strong>{t(locale, "banner.warning")}</strong> {cfg.message}
          {cfg.docsUrl && (
            <>
              {" "}
              <a href={cfg.docsUrl} target="_blank" rel="noopener noreferrer">
                {cfg.docsLabel ?? t(locale, "banner.docs")}
              </a>
              .
            </>
          )}
        </Banner>
      ))
    }
    <slot />
    <footer class="site-footer">© {year} Jakub Zasański <span class="site-footer__version">v{version}</span></footer>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
  }
  /* min-height (not height:100%) so the warm body background spans the full
     content on long pages (e.g. the landing) instead of cutting off after one
     viewport. */
  body {
    min-height: 100dvh;
  }
</style>
