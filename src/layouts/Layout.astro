---
import "../styles/global.css";
import Banner from "@/components/Banner.astro";
import { missingConfigs } from "@/lib/config-status";
import { t } from "@/i18n";

interface Props {
  title?: string;
}

const { title = "Sage Flashcards" } = Astro.props;
const locale = Astro.locals.locale;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    {/* Apply the theme before first paint to avoid a flash of the wrong theme. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("sage-theme");
          var dark = stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches;
          if (dark) document.documentElement.classList.add("dark");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    {
      missingConfigs.map((cfg) => (
        <Banner variant="error">
          <strong>{t(locale, "banner.warning")}</strong> {cfg.message}
          {cfg.docsUrl && (
            <>
              {" "}
              <a href={cfg.docsUrl} target="_blank" rel="noopener noreferrer">
                {cfg.docsLabel ?? t(locale, "banner.docs")}
              </a>
              .
            </>
          )}
        </Banner>
      ))
    }
    <slot />
    <footer class="site-footer">© {year} Jakub Zasański</footer>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
  }
  /* min-height (not height:100%) so the warm body background spans the full
     content on long pages (e.g. the landing) instead of cutting off after one
     viewport. */
  body {
    min-height: 100dvh;
  }
</style>
