# Dependabot otherwise misclassifies the public @openai/* scoped packages
# (@openai/codex pulls npm:-aliased platform builds) as a private registry and
# errors the npm ecosystem run ("can't access a private package registry").
# Pinning the scope to the public registry makes resolution explicit.
# See dependabot-core#13797. No functional change — npm already uses this registry.
@openai:registry=https://registry.npmjs.org/
